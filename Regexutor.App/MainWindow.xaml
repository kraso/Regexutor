<Window x:Class="Regexutor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Regexutor.App"
        mc:Ignorable="d"
        Title="Regexutor" Height="760" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FF3B30"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#55FF3B30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0F0F0F" Offset="0"/>
            <GradientStop Color="#FF2A2A2A" Offset="0.30"/>
            <GradientStop Color="#FFF6F6F6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="16" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12,0"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="#22FFFFFF"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border.Background>
                <!-- Barra superior “cristalina” (oscura y translúcida) -->
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#99000000" Offset="0"/>
                    <GradientStop Color="#55000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Height="44">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="{Binding AppName}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"/>

                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Padding="10,6"
                        CornerRadius="999"
                        Background="#DFFFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1">
                    <TextBlock Text="{Binding EngineStatus}"
                               Foreground="{Binding EngineStatusBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Botones de ventana -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,-12,0">
                    <Button Height="28"
                            Margin="0,0,10,0"
                            Padding="10,0"
                            VerticalAlignment="Center"
                            Background="#22FFFFFF"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Content="Información adicional"
                            Click="AdditionalInfo_Click"/>
                    <Button Width="44" Height="44" Style="{StaticResource TitleBarButtonStyle}"
                            Click="Minimize_Click" ToolTip="Minimizar">
                        <TextBlock Text="─" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Width="44" Height="44" Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestore_Click" ToolTip="Maximizar / Restaurar">
                        <TextBlock Text="▢" Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Width="44" Height="44" Style="{StaticResource CloseTitleBarButtonStyle}"
                            Click="Close_Click" ToolTip="Cerrar">
                        <TextBlock Text="✕" Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,14,0,0" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Práctica">
                <Grid Margin="0,10,0,0" ToolTip="Ejercicios fijos con más casos por nivel. Los exámenes van en su propia pestaña.">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12" Background="#0A004D99" BorderBrush="#330066CC" BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#CC003366"
                                       Text="Modo práctica — ejercicios fijos y ampliados por nivel (sin exámenes aleatorios aquí)."/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                                <TextBlock Text="Ejercicio" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding PracticeExercises}"
                                          SelectedItem="{Binding SelectedExercise}"
                                          DisplayMemberPath="Title"
                                          Margin="0,6,0,0"
                                          MinWidth="520"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,8,0,0" VerticalAlignment="Top">
                                <TextBlock Text="Dialecto" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedDialectLabel}" Margin="0,6,0,0"/>
                                <Button Content="Ver teoría relacionada"
                                        Command="{Binding GoToTheoryCommand}"
                                        Margin="0,10,0,0"
                                        Padding="10,6"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <TextBlock Text="Enunciado" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding SelectedPrompt, Mode=OneWay}"
                                         Margin="0,6,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Padding="0"
                                         Cursor="IBeam"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Left" Margin="0,0,12,0">
                                        <TextBlock Text="Tu expresión regular" FontWeight="SemiBold"/>
                                        <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas"
                                                 FontSize="16"
                                                 Margin="0,6,0,0"
                                                 MinWidth="680"/>
                                    </StackPanel>
                                    <Button Content="{Binding EvaluateButtonText}"
                                            Command="{Binding EvaluateCommand}"
                                            IsEnabled="{Binding CanEvaluate}"
                                            Padding="16,10"
                                            VerticalAlignment="Bottom"
                                            MinWidth="140"/>
                                </DockPanel>
                                <TextBox Text="{Binding LastSummary, Mode=OneWay}"
                                         Margin="0,10,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Padding="0"
                                         Cursor="IBeam"/>
                                <ItemsControl ItemsSource="{Binding LastHints}" Margin="0,8,0,0" Visibility="{Binding HasHints, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="• "/>
                                                <Run Text="{Binding Path=., Mode=OneWay}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Casos de prueba" FontWeight="SemiBold"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding LastResults}" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Entrada (· = espacio)" Binding="{Binding InputDisplay}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="ToolTip" Value="{Binding InputTooltip}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Esperado" Binding="{Binding Expected}" Width="120"/>
                                <DataGridTextColumn Header="Resultado" Binding="{Binding Actual}" Width="120"/>
                                <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Teoría">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Temario" FontWeight="SemiBold"/>
                        </StackPanel>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding TheoryTopics}"
                                 SelectedItem="{Binding SelectedTheoryTopic}"
                                 DisplayMemberPath="Title"
                                 VerticalAlignment="Stretch"
                                 MinHeight="260"/>
                    </Grid>

                    <Border Grid.Column="2" Padding="12" Background="#0A000000" BorderBrush="#22000000" BorderThickness="1" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedTheoryTitle}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SelectedTheoryBody, Mode=OneWay}"
                                     Margin="0,10,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="0"
                                     Cursor="IBeam"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Exámenes">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12" Background="#14003366" BorderBrush="#55336699" BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#E0334477"
                                       Text="Modo examen — generación aleatoria (independiente de la pestaña Práctica). La práctica no mezcla exámenes en el mismo listado."/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                                <TextBlock Text="Plantilla de examen" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding ExamTemplates}"
                                          SelectedItem="{Binding SelectedExamTemplate}"
                                          DisplayMemberPath="Title"
                                          Margin="0,6,0,0"
                                          MinWidth="520"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" FontSize="12" Opacity="0.9"
                                           Text="{Binding SelectedExamTemplate.ShortHelp, TargetNullValue=''}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Nuevo examen aleatorio"
                                            Command="{Binding GenerateExamCommand}"
                                            Padding="10,6" Margin="0,0,8,0"/>
                                    <Button Content="Repetir último examen"
                                            Command="{Binding RepeatLastExamCommand}"
                                            Padding="10,6"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,10,0,0" VerticalAlignment="Top">
                                <TextBlock Text="Dialecto (examen activo)" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedDialectLabel}" Margin="0,6,0,0"/>
                                <Button Content="Ver teoría relacionada"
                                        Command="{Binding GoToTheoryCommand}"
                                        Margin="0,10,0,0"
                                        Padding="10,6"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,14,0,0">
                                <TextBlock Text="Enunciado del examen" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding SelectedPrompt, Mode=OneWay}"
                                         Margin="0,6,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Padding="0"
                                         Cursor="IBeam"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Left" Margin="0,0,12,0">
                                        <TextBlock Text="Tu expresión regular" FontWeight="SemiBold"/>
                                        <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas"
                                                 FontSize="16"
                                                 Margin="0,6,0,0"
                                                 MinWidth="680"/>
                                    </StackPanel>
                                    <Button Content="{Binding EvaluateButtonText}"
                                            Command="{Binding EvaluateCommand}"
                                            IsEnabled="{Binding CanEvaluate}"
                                            Padding="16,10"
                                            VerticalAlignment="Bottom"
                                            MinWidth="140"/>
                                </DockPanel>
                                <TextBox Text="{Binding LastSummary, Mode=OneWay}"
                                         Margin="0,10,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Padding="0"
                                         Cursor="IBeam"/>
                                <ItemsControl ItemsSource="{Binding LastHints}" Margin="0,8,0,0" Visibility="{Binding HasHints, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="• "/>
                                                <Run Text="{Binding Path=., Mode=OneWay}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Casos de prueba del examen" FontWeight="SemiBold"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding LastResults}" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Entrada (· = espacio)" Binding="{Binding InputDisplay}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="ToolTip" Value="{Binding InputTooltip}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Esperado" Binding="{Binding Expected}" Width="120"/>
                                <DataGridTextColumn Header="Resultado" Binding="{Binding Actual}" Width="120"/>
                                <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Acerca de">
                <Grid Margin="0,10,0,0">
                    <Border Padding="20"
                            Background="#0A000000"
                            BorderBrush="#22000000"
                            BorderThickness="1"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding AppName, Mode=OneWay}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Versión" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text=":"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding AppVersion, Mode=OneWay}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Fecha" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text=":" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding AppDate, Mode=OneWay}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Autor" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text=":" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding AppAuthor, Mode=OneWay}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Email" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text=":" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding AppEmail, Mode=OneWay}" Margin="0,6,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
