<Window x:Class="Regexutor.App.AdditionalInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Información adicional"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterOwner">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0F0F0F" Offset="0"/>
            <GradientStop Color="#FF2A2A2A" Offset="0.30"/>
            <GradientStop Color="#FFF6F6F6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Información adicional — Esquema rápido de regex (traducido)"
                   Foreground="White"
                   FontWeight="Bold"
                   FontSize="18"/>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Secciones" FontWeight="SemiBold" Foreground="White"/>
                <ListBox ItemsSource="{Binding CheatSheetTopics}"
                         SelectedItem="{Binding SelectedCheatSheetTopic}"
                         DisplayMemberPath="Title"
                         Margin="0,8,0,0"
                         MinHeight="260"/>
            </StackPanel>

            <Border Grid.Column="2" Padding="12" Background="#0A000000" BorderBrush="#22000000" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedCheatSheetTitle}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SelectedCheatSheetBody, Mode=OneWay}"
                             Margin="0,10,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Padding="0"
                             Cursor="IBeam"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

